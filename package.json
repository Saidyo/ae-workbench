{
  "name": "ae-workbench",
  "version": "0.1.0",
  "description": "A local desktop workstation for After Effects project and asset management.",
  "private": true,
  "author": "Saidyo",
  "license": "MIT",
  "homepage": "https://github.com/Saidyo/ae-workbench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saidyo/ae-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/Saidyo/ae-workbench/issues"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^38.2.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
